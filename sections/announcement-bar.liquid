{{ 'section-announcement-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign social_icons = false
  endif
  if section.settings.enable_country_selector or section.settings.enable_language_selector
    assign language_country_selector = true
  endif

  # Show grid layout for non-marquee modes if social/localization is active
  assign show_grid = false
  if section.settings.layout_mode != 'marquee'
    if social_icons and section.settings.show_social
      assign show_grid = true
    endif
    if language_country_selector
      assign show_grid = true
    endif
  endif

  # Determine if we default to the custom Ayira Forest Green/Gold palette
  assign use_ayira_theme = false
  if section.settings.color_scheme == 'scheme-4' or section.settings.color_scheme == blank
    assign use_ayira_theme = true
  endif
-%}

{%- if social_icons and section.settings.show_social and section.settings.layout_mode != 'marquee' -%}
  {{ 'component-list-social.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.blocks.size > 0 -%}
  <div
    id="AyiraAnnouncementBar-{{ section.id }}"
    class="ayira-announcement-bar-container {% if use_ayira_theme %}ayira-theme-default{% else %}color-{{ section.settings.color_scheme }} gradient{% endif %}{% if section.settings.show_line_separator %} utility-bar--bottom-border{% endif %}"
    role="region"
    aria-label="{{ 'sections.header.announcement' | t }}"
  >
    {%- if section.settings.layout_mode == 'marquee' -%}
      {%- capture marquee_items -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank and block.settings.link_label == blank -%}
            <a href="{{ block.settings.link }}" class="ayira-announcement-bar__marquee-text is-link" {{ block.shopify_attributes }}>
              {{ block.settings.text | escape }}
            </a>
          {%- else -%}
            <span class="ayira-announcement-bar__marquee-text" {{ block.shopify_attributes }}>
              <span>{{ block.settings.text | escape }}</span>
              {%- if block.settings.link != blank and block.settings.link_label != blank -%}
                <a href="{{ block.settings.link }}" class="ayira-announcement-bar__cta">
                  {{ block.settings.link_label | escape }}
                  <span class="cta-arrow">→</span>
                </a>
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- capture marquee_items_hidden -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank and block.settings.link_label == blank -%}
            <a href="{{ block.settings.link }}" class="ayira-announcement-bar__marquee-text is-link" tabindex="-1" aria-hidden="true">
              {{ block.settings.text | escape }}
            </a>
          {%- else -%}
            <span class="ayira-announcement-bar__marquee-text" aria-hidden="true">
              <span>{{ block.settings.text | escape }}</span>
              {%- if block.settings.link != blank and block.settings.link_label != blank -%}
                <a href="{{ block.settings.link }}" class="ayira-announcement-bar__cta" tabindex="-1">
                  {{ block.settings.link_label | escape }}
                  <span class="cta-arrow">→</span>
                </a>
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div class="ayira-announcement-bar__marquee-wrapper" style="--marquee-speed: {{ section.settings.marquee_speed }}s;">
        <div class="ayira-announcement-bar__marquee-inner">
          <div class="ayira-announcement-bar__marquee-group">
            {{ marquee_items }}
            {%- if section.blocks.size < 4 -%}
              {{ marquee_items }}
              {{ marquee_items }}
            {%- endif -%}
          </div>
          <div class="ayira-announcement-bar__marquee-group" aria-hidden="true">
            {{ marquee_items_hidden }}
            {%- if section.blocks.size < 4 -%}
              {{ marquee_items_hidden }}
              {{ marquee_items_hidden }}
            {%- endif -%}
          </div>
        </div>
      </div>

    {%- else -%}
      <div class="page-width {% if show_grid %}utility-bar__grid{% if social_icons and section.settings.show_social and language_country_selector %} utility-bar__grid--3-col{% elsif language_country_selector or social_icons and section.settings.show_social %} utility-bar__grid--2-col{% endif %}{% endif %}">
        {%- if section.settings.show_social and social_icons -%}
          {%- render 'social-icons' -%}
        {%- endif -%}

        <div class="ayira-announcement-bar__content-wrapper">
          {%- if section.settings.layout_mode == 'single' -%}
            {%- assign block = section.blocks.first -%}
            {%- if block != blank -%}
              <div class="ayira-announcement-bar" {{ block.shopify_attributes }}>
                <p class="ayira-announcement-bar__message h5">
                  <span>{{ block.settings.text | escape }}</span>
                  {%- if block.settings.link != blank -%}
                    {%- if block.settings.link_label != blank -%}
                      <a href="{{ block.settings.link }}" class="ayira-announcement-bar__cta">
                        {{ block.settings.link_label | escape }}
                        <span class="cta-arrow">→</span>
                      </a>
                    {%- else -%}
                      <a href="{{ block.settings.link }}" class="ayira-announcement-bar__link-overlay"></a>
                    {%- endif -%}
                  {%- endif -%}
                </p>
              </div>
            {%- endif -%}

          {%- elsif section.settings.layout_mode == 'carousel' -%}
            <div class="ayira-announcement-bar__carousel">
              {%- if section.blocks.size > 1 -%}
                <button
                  type="button"
                  class="ayira-announcement-bar__arrow ayira-announcement-bar__arrow--prev"
                  aria-label="Previous Announcement"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </button>
              {%- endif -%}

              <div class="ayira-announcement-bar__slides">
                {%- for block in section.blocks -%}
                  <div
                    class="ayira-announcement-bar__slide {% if forloop.first %}is-active{% endif %}"
                    data-index="{{ forloop.index0 }}"
                    {{ block.shopify_attributes }}
                  >
                    <p class="ayira-announcement-bar__message h5">
                      <span>{{ block.settings.text | escape }}</span>
                      {%- if block.settings.link != blank -%}
                        {%- if block.settings.link_label != blank -%}
                          <a href="{{ block.settings.link }}" class="ayira-announcement-bar__cta">
                            {{ block.settings.link_label | escape }}
                            <span class="cta-arrow">→</span>
                          </a>
                        {%- else -%}
                          <a href="{{ block.settings.link }}" class="ayira-announcement-bar__link-overlay"></a>
                        {%- endif -%}
                      {%- endif -%}
                    </p>
                  </div>
                {%- endfor -%}
              </div>

              {%- if section.blocks.size > 1 -%}
                <button
                  type="button"
                  class="ayira-announcement-bar__arrow ayira-announcement-bar__arrow--next"
                  aria-label="Next Announcement"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if language_country_selector -%}
          <div class="localization-wrapper">
            {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
              <localization-form class="small-hide medium-hide">
                {%- form 'localization', id: 'AnnouncementCountryForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="AnnouncementCountryLabel">{{ 'localization.country_label' | t }}</h2>
                    {%- render 'country-localization', localPosition: 'AnnouncementCountry' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {% endif %}

            {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
              <localization-form class="small-hide medium-hide">
                {%- form 'localization', id: 'AnnouncementLanguageForm', class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="AnnouncementLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                    {%- render 'language-localization', localPosition: 'AnnouncementLanguage' -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

{%- if section.settings.layout_mode == 'carousel' and section.blocks.size > 1 -%}
  <script>
    (function() {
      function initCarousel() {
        const container = document.getElementById('AyiraAnnouncementBar-{{ section.id }}');
        if (!container) return;

        // Prevent double initialization
        if (container.dataset.carouselInitialized) return;
        container.dataset.carouselInitialized = 'true';

        const slides = container.querySelectorAll('.ayira-announcement-bar__slide');
        const prevBtn = container.querySelector('.ayira-announcement-bar__arrow--prev');
        const nextBtn = container.querySelector('.ayira-announcement-bar__arrow--next');
        if (slides.length <= 1) return;

        let currentIndex = 0;
        let intervalId = null;
        const speed = parseInt('{{ section.settings.change_slides_speed | default: 5 }}') * 1000;

        function showSlide(index) {
          slides.forEach(slide => slide.classList.remove('is-active'));
          slides[index].classList.add('is-active');
          currentIndex = index;
        }

        function nextSlide() {
          let index = currentIndex + 1;
          if (index >= slides.length) index = 0;
          showSlide(index);
        }

        function prevSlide() {
          let index = currentIndex - 1;
          if (index < 0) index = slides.length - 1;
          showSlide(index);
        }

        if (prevBtn && nextBtn) {
          prevBtn.addEventListener('click', function() {
            prevSlide();
            resetAutoplay();
          });
          nextBtn.addEventListener('click', function() {
            nextSlide();
            resetAutoplay();
          });
        }

        function startAutoplay() {
          {%- if section.settings.auto_rotate -%}
            if (intervalId) clearInterval(intervalId);
            intervalId = setInterval(nextSlide, speed);
          {%- endif -%}
        }

        function resetAutoplay() {
          startAutoplay();
        }

        // Initialize first slide display
        showSlide(0);
        startAutoplay();

        // Save cleanup on element to avoid memory leaks or duplicate intervals on theme editor reload
        container._carouselCleanup = function() {
          if (intervalId) clearInterval(intervalId);
        };
      }

      // Initialize on DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCarousel);
      } else {
        initCarousel();
      }

      // Theme editor integration
      document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          // Clean up old carousel if it exists
          const oldContainer = document.getElementById('AyiraAnnouncementBar-{{ section.id }}');
          if (oldContainer && oldContainer._carouselCleanup) {
            oldContainer._carouselCleanup();
          }
          initCarousel();
        }
      });

      document.addEventListener('shopify:section:unload', function(event) {
        if (event.detail.sectionId === '{{ section.id }}') {
          const oldContainer = document.getElementById('AyiraAnnouncementBar-{{ section.id }}');
          if (oldContainer && oldContainer._carouselCleanup) {
            oldContainer._carouselCleanup();
          }
        }
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout Mode",
      "default": "single",
      "options": [
        {
          "value": "single",
          "label": "Single Message"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "marquee",
          "label": "Scrolling Marquee"
        }
      ]
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Marquee Speed",
      "default": 20,
      "info": "Duration in seconds to scroll across screen. Lower is faster."
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-bar.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.announcement-bar.settings.change_slides_speed.label",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4",
      "info": "Leave as Default Scheme-4 to use the custom Ayira signature Forest Green and Gold palette."
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "header",
      "content": "t:sections.announcement-bar.settings.heading_utilities.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.announcement-bar.settings.paragraph.content"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.announcement-bar.settings.show_social.label",
      "info": "t:sections.announcement-bar.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_country_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.announcement-bar.settings.enable_language_selector.label",
      "info": "t:sections.announcement-bar.settings.enable_language_selector.info"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label (CTA)",
          "info": "If left blank, the entire announcement block text will be clickable instead of showing an underlined CTA link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
