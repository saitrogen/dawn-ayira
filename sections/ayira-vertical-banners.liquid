{%- style -%}
  #AyiraVerticalBanners-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #AyiraVerticalBanners-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="AyiraVerticalBanners-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient"
>
  <div class="ayira-vertical-banners page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank or section.settings.show_view_all -%}
      <div class="ayira-vertical-banners__header">
        <div class="ayira-vertical-banners__header-left">
          {%- if section.settings.eyebrow != blank -%}
            <span class="ayira-vertical-banners__eyebrow">
              {{- section.settings.eyebrow | escape -}}
            </span>
          {%- endif -%}
          {%- if section.settings.title != blank -%}
            <h2 class="ayira-vertical-banners__title">
              {{- section.settings.title -}}
            </h2>
          {%- endif -%}
        </div>

        {%- if section.settings.show_view_all and section.settings.view_all_link != blank -%}
          <a
            href="{{ section.settings.view_all_link }}"
            class="ayira-vertical-banners__view-all"
            aria-label="{{ section.settings.view_all_label | escape }}"
          >
            {{- section.settings.view_all_label | default: 'View all' | escape -}}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M3 8H13M13 8L8.5 3.5M13 8L8.5 12.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul
      class="ayira-vertical-banners__track"
      role="list"
    >
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign delay_order = forloop.index
          -%}
          <li
            class="ayira-vertical-banners__track-item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              style="--animation-order: {{ delay_order }};"
              data-cascade
            {% endif %}
          >
            <a
              {% if block.settings.link != blank %}
                href="{{ block.settings.link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="ayira-vertical-banner"
              style="--banner-bg: {{ block.settings.background_color }}; --banner-fg: {{ block.settings.text_color }};"
            >
              {%- if block.settings.title != blank -%}
                <h3 class="ayira-vertical-banner__title">
                  {{ block.settings.title }}
                </h3>
              {%- endif -%}

              <div class="ayira-vertical-banner__media">
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign alt_text = block.settings.image.alt | default: block.settings.title | escape
                  -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      width: block.settings.image.width,
                      height: block.settings.image.height,
                      alt: alt_text,
                      class: 'ayira-vertical-banner__img',
                      loading: 'lazy',
                      widths: '200, 300, 400, 500, 600, 700, 800'
                  }}
                {%- else -%}
                  {%- assign placeholder_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {{ 'product-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg ayira-vertical-banner__img' }}
                {%- endif -%}
              </div>

              <div class="ayira-vertical-banner__overlay"></div>
            </a>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..5) -%}
          {%- liquid
            case i
              when 1
                assign bg_color = '#D4A737'
                assign title = 'Grocery'
              when 2
                assign bg_color = '#B42318'
                assign title = 'Fresh'
              when 3
                assign bg_color = '#0D4F47'
                assign title = 'Snacks'
              when 4
                assign bg_color = '#D4A737'
                assign title = 'Beverages'
              else
                assign bg_color = '#0D4F47'
                assign title = 'Frozen'
            endcase
          -%}
          <li class="ayira-vertical-banners__track-item">
            <div
              class="ayira-vertical-banner"
              style="--banner-bg: {{ bg_color }}; --banner-fg: #FFFFFF;"
            >
              <h3 class="ayira-vertical-banner__title">
                {{ title }}
              </h3>
              <div class="ayira-vertical-banner__media">
                {%- assign placeholder_index = i | minus: 1 | modulo: 4 | plus: 1 -%}
                {{ 'product-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg ayira-vertical-banner__img' }}
              </div>
              <div class="ayira-vertical-banner__overlay"></div>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</div>

{% stylesheet %}
.ayira-vertical-banners {
  overflow: hidden;
}

.ayira-vertical-banners__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 24px;
}

.ayira-vertical-banners__header-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.ayira-vertical-banners__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent, #D4A737);
  line-height: 1;
}

.ayira-vertical-banners__title {
  font-size: clamp(1.75rem, 3.5vw, 2.6rem);
  font-weight: 700;
  line-height: 1.1;
  color: var(--color-ink-900, #101828);
  margin: 0;
  font-family: var(--font-heading-family, inherit);
}

.ayira-vertical-banners__view-all {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 14px;
  font-weight: 600;
  color: var(--color-ink-900, #101828);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  margin-bottom: 4px;
  transition: color 0.2s ease;
}

.ayira-vertical-banners__view-all:hover {
  color: var(--accent, #D4A737);
}

.ayira-vertical-banners__view-all svg {
  transition: transform 0.2s ease;
}

.ayira-vertical-banners__view-all:hover svg {
  transform: translateX(3px);
}

.ayira-vertical-banners__track {
  display: flex;
  gap: 16px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 8px 4px 16px 4px;
  list-style: none;
  margin: 0;
}

.ayira-vertical-banners__track::-webkit-scrollbar {
  display: none;
}

.ayira-vertical-banners__track-item {
  flex: 0 0 160px;
  scroll-snap-align: start;
  display: flex;
}

@media screen and (min-width: 750px) {
  .ayira-vertical-banners__track-item {
    flex: 0 0 220px;
  }
}

.ayira-vertical-banner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  aspect-ratio: 9 / 16;
  padding: 16px;
  background-color: var(--banner-bg, #D4A737);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              box-shadow 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  -webkit-tap-highlight-color: transparent;
  width: 100%;
}

.ayira-vertical-banner:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.12), 0 4px 6px -2px rgba(0, 0, 0, 0.08);
}

.ayira-vertical-banner__title {
  font-size: clamp(1.2rem, 2vw, 1.8rem);
  font-weight: 800;
  line-height: 1.2;
  color: var(--banner-fg, #FFFFFF);
  margin: 0;
  font-family: var(--font-heading-family, inherit);
  text-transform: capitalize;
  letter-spacing: -0.01em;
  z-index: 2;
  word-wrap: break-word;
}

.ayira-vertical-banner__media {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.ayira-vertical-banner__media .ayira-vertical-banner__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ayira-vertical-banner__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 35%, rgba(0, 0, 0, 0) 60%);
  z-index: 1.5;
  pointer-events: none;
}

.ayira-vertical-banner__img {
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ayira-vertical-banner:hover .ayira-vertical-banner__img {
  transform: scale(1.04);
}

@media screen and (max-width: 749px) {
  .ayira-vertical-banners__track {
    gap: 8px;
    margin-right: -24px;
    padding-right: 24px;
  }

  .ayira-vertical-banners__track-item {
    flex: 0 0 calc((100vw - 40px) / 2.7);
  }
  
  .ayira-vertical-banner {
    padding: 10px;
    border-radius: 12px;
  }
  
  .ayira-vertical-banner__title {
    font-size: 1.1rem;
    line-height: 1.15;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Ayira Vertical Banners",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Browse"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show view all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all link text",
      "default": "All Categories"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link URL"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Vertical Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner image"
        },
        {
          "type": "inline_richtext",
          "id": "title",
          "label": "Heading",
          "default": "Category Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Card background color",
          "default": "#D4A737"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Card text color",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ayira Vertical Banners",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "title": "Grocery Essentials",
            "background_color": "#D4A737",
            "text_color": "#FFFFFF"
          }
        },
        {
          "type": "banner",
          "settings": {
            "title": "Fresh & Chilled",
            "background_color": "#B42318",
            "text_color": "#FFFFFF"
          }
        },
        {
          "type": "banner",
          "settings": {
            "title": "Snacks & Chocolates",
            "background_color": "#0D4F47",
            "text_color": "#FFFFFF"
          }
        }
      ]
    }
  ]
}
{% endschema %}
