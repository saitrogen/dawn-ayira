<!-- sections/ayira-header.liquid -->
{{ 'section-ayira-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ayira-header.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign menu = section.settings.menu
  assign color_scheme = section.settings.color_scheme
  assign sticky_type = section.settings.sticky_header_type
-%}

<style>
  :root {
    --ayira-logo-max-height: {{ section.settings.logo_height }}px;
    --ayira-logo-max-height-mobile: {{ section.settings.logo_height_mobile }}px;
  }
</style>

<ayira-sticky-header data-sticky-type="{{ sticky_type }}" class="ayira-header-wrapper color-{{ color_scheme }} gradient">
  <header class="ayira-header">
    
    <!-- DESKTOP ROW 1 -->
    <div class="ayira-header__row-1">
      <!-- 1. Search Bar (Modular Snippet) -->
      <div class="ayira-header__search-container">
        {%- render 'ayira-header-search', input_id: 'Header-Search-Desktop' -%}
      </div>

      <!-- 2. Store Logo Centered -->
      <div class="ayira-header__logo-container">
        <a href="{{ routes.root_url }}" class="ayira-header__logo-link">
          {%- if settings.logo != blank or section.settings.logo_light != blank -%}
            {%- assign logo_width = section.settings.logo_width -%}
            {%- if settings.logo != blank -%}
              {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
              {%- assign logo_height = logo_width | divided_by: settings.logo.aspect_ratio -%}
              {{ settings.logo | image_url: width: 400 | image_tag:
                class: 'ayira-header__logo-image logo-default',
                height: logo_height,
                width: logo_width,
                alt: logo_alt,
                preload: true
              }}
            {%- endif -%}
            {%- if section.settings.logo_light != blank -%}
              {%- assign logo_light_alt = section.settings.logo_light.alt | default: shop.name | escape -%}
              {%- assign logo_light_height = logo_width | divided_by: section.settings.logo_light.aspect_ratio -%}
              {{ section.settings.logo_light | image_url: width: 400 | image_tag:
                class: 'ayira-header__logo-image logo-light',
                height: logo_light_height,
                width: logo_width,
                alt: logo_light_alt,
                preload: true
              }}
            {%- endif -%}
          {%- else -%}
            <span class="ayira-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- 3. Icon Buttons Right -->
      <div class="ayira-header__icons-container">
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="ayira-header__icon-btn" aria-label="Account">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="10" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.8"/>
              <path d="M2 19.5C2 16.1863 5.58172 13.5 10 13.5C14.4183 13.5 18 16.1863 18 19.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </a>
        {%- endif -%}

        <!-- Wishlist -->
        <button class="ayira-header__icon-btn" aria-label="Wishlist">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 17.5C10 17.5 2.5 13 2.5 7.5C2.5 4.5 4.8 2.5 7.5 2.5C9.2 2.5 10 3.8 10 3.8C10 3.8 10.8 2.5 12.5 2.5C15.2 2.5 17.5 4.5 17.5 7.5C17.5 13 10 17.5 10 17.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Cart Link -->
        <a href="{{ routes.cart_url }}" class="ayira-header__icon-btn" aria-label="Cart" id="cart-icon-bubble">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 6H17L18.5 18H1.5L3 6Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M7 9V5C7 3.34315 8.34315 2 10 2C11.6569 2 13 3.34315 13 5V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          {%- if cart != empty -%}
            <span class="ayira-header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>

    <!-- DESKTOP ROW 2 (Centered Navigation) -->
    {%- if menu != blank -%}
      <div class="ayira-header__row-2">
        <nav class="ayira-header__navigation">
          <ul class="ayira-header__nav-list">
            {%- for link in menu.links -%}
              {%- assign is_active = false -%}
              {%- if link.active or link.child_active -%}
                {%- assign is_active = true -%}
              {%- endif -%}

              <li class="ayira-header__nav-item{% if is_active %} ayira-header__nav-item--active{% endif %}">
                <a href="{{ link.url }}" class="ayira-header__nav-link">
                  {{ link.title | escape }}
                  {%- if link.links.size > 0 -%}
                    <span class="ayira-header__caret">
                      <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  {%- endif -%}
                </a>

                {%- if link.links.size > 0 -%}
                  <div class="ayira-header__dropdown">
                    <ul class="ayira-header__dropdown-list">
                      {%- for child_link in link.links -%}
                        <li>
                          <a href="{{ child_link.url }}" class="ayira-header__dropdown-link">
                            {{ child_link.title | escape }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>
    {%- endif -%}

    <!-- MOBILE VIEW (1-row Header) -->
    <div class="ayira-header__mobile">
      <div class="ayira-header__mobile-left">
        <!-- Hamburger Menu Drawer Toggle -->
        <button id="AyiraDrawerOpen" class="ayira-header__icon-btn" aria-label="Menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 12H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M3 6H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M3 18H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>

        <!-- Mobile Search Toggle Button -->
        <button id="AyiraSearchToggle" class="ayira-header__icon-btn" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 15C11.866 15 15 11.866 15 8C15 4.13401 11.866 1 8 1C4.13401 1 1 4.13401 1 8C1 11.866 4.13401 15 8 15Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M19 19L13.5 13.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Mobile Logo Center -->
      <div class="ayira-header__logo-container">
        <a href="{{ routes.root_url }}" class="ayira-header__logo-link">
          {%- if settings.logo != blank or section.settings.logo_light != blank -%}
            {%- assign logo_width = section.settings.logo_width | at_most: 100 -%}
            {%- if settings.logo != blank -%}
              {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
              {{ settings.logo | image_url: width: 250 | image_tag:
                class: 'ayira-header__logo-image logo-default',
                height: 35,
                width: logo_width,
                alt: logo_alt
              }}
            {%- endif -%}
            {%- if section.settings.logo_light != blank -%}
              {%- assign logo_light_alt = section.settings.logo_light.alt | default: shop.name | escape -%}
              {{ section.settings.logo_light | image_url: width: 250 | image_tag:
                class: 'ayira-header__logo-image logo-light',
                height: 35,
                width: logo_width,
                alt: logo_light_alt
              }}
            {%- endif -%}
          {%- else -%}
            <span class="ayira-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Mobile Cart Right -->
      <div class="ayira-header__mobile-right">
        <a href="{{ routes.cart_url }}" class="ayira-header__icon-btn" aria-label="Cart">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 6H17L18.5 18H1.5L3 6Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M7 9V5C7 3.34315 8.34315 2 10 2C11.6569 2 13 3.34315 13 5V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          {%- if cart != empty -%}
            <span class="ayira-header__cart-badge">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Toggleable Mobile Search Input Panel (Modular Snippet) -->
      <div id="AyiraMobileSearchPanel" class="ayira-header__mobile-search-overlay">
        {%- render 'ayira-header-search', input_id: 'Header-Search-Mobile' -%}
      </div>
    </div>
  </header>

  <!-- MOBILE DRAWER CONTAINER -->
  <div id="AyiraMobileDrawer" class="ayira-header__drawer">
    <div class="ayira-header__drawer-content">
      <div class="ayira-header__drawer-header">
        <span class="ayira-header__logo-text" style="font-size: 2rem;">Menu</span>
        <button id="AyiraDrawerClose" class="ayira-header__drawer-close" aria-label="Close menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      
      {%- if menu != blank -%}
        <nav class="ayira-header__drawer-nav">
          {%- for link in menu.links -%}
            <div class="ayira-header__drawer-item">
              <a href="{{ link.url }}" class="ayira-header__drawer-link">
                {{ link.title | escape }}
                {%- if link.links.size > 0 -%}
                  <svg class="ayira-header__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              </a>

              {%- if link.links.size > 0 -%}
                <ul class="ayira-header__drawer-submenu">
                  {%- for child_link in link.links -%}
                    <li>
                      <a href="{{ child_link.url }}" class="ayira-header__drawer-sublink">
                        {{ child_link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </nav>
      {%- endif -%}
    </div>
  </div>
</ayira-sticky-header>

{% schema %}
{
  "name": "Ayira Header",
  "class": "section-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "logo_light",
      "label": "Light / Cream Logo (for Dark Headers)"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 220,
      "step": 10,
      "unit": "px",
      "label": "Desktop Logo Width",
      "default": 110
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logo Max Height (Desktop)",
      "default": 50
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "min": 12,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Logo Max Height (Mobile)",
      "default": 32
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "always",
          "label": "Always Sticky"
        },
        {
          "value": "on-scroll-up",
          "label": "Sticky on Scroll Up"
        }
      ],
      "default": "always",
      "label": "Sticky Header Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Ayira Header"
    }
  ]
}
{% endschema %}
