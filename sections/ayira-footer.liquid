{{ 'section-ayira-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .ayira-footer--{{ section.id }} {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .ayira-footer--{{ section.id }} {
      margin-top: {{ section.settings.margin_top }}px;
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="ayira-footer ayira-footer--{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="ayira-footer__inner page-width">
    {%- if section.settings.newsletter_enable -%}
      <div class="ayira-footer__newsletter">
        <div class="ayira-footer__newsletter-copy">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="ayira-footer__title inline-richtext">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.newsletter_text != blank -%}
            <div class="ayira-footer__intro rte">{{ section.settings.newsletter_text }}</div>
          {%- endif -%}
        </div>

        {%- form 'customer', id: 'AyiraFooterNewsletter', class: 'ayira-footer__form newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="AyiraNewsletter--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}aria-invalid="true" aria-describedby="AyiraFooter-error"{% endif %}
                {% if form.posted_successfully? %}aria-describedby="AyiraFooter-success"{% endif %}
                placeholder="{{ 'newsletter.label' | t }}"
                required
              >
              <label class="field__label" for="AyiraNewsletter--{{ section.id }}">{{ 'newsletter.label' | t }}</label>
              <button type="submit" class="newsletter-form__button field__button" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">
                <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="AyiraFooter-error">
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>
          {%- if form.posted_successfully? -%}
            <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="AyiraFooter-success" tabindex="-1" autofocus>
              <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
              {{- 'newsletter.success' | t }}
            </h3>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ayira-footer__blocks">
        {%- for block in section.blocks -%}
          <div class="ayira-footer__block ayira-footer__block--{{ block.type }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'link_list' -%}
                <div class="ayira-footer__desktop-menu">
                  <h2 class="ayira-footer__heading inline-richtext">{{ block.settings.heading }}</h2>
                  {%- render 'ayira-footer-links', menu: block.settings.menu -%}
                </div>
                <details class="ayira-footer__mobile-menu">
                  <summary class="ayira-footer__summary">
                    <span>{{ block.settings.heading }}</span>
                    <span class="ayira-footer__toggle" aria-hidden="true"></span>
                  </summary>
                  {%- render 'ayira-footer-links', menu: block.settings.menu -%}
                </details>
              {%- when 'text' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="ayira-footer__heading inline-richtext">{{ block.settings.heading }}</h2>
                {%- endif -%}
                <div class="ayira-footer__text rte">{{ block.settings.subtext }}</div>
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_social -%}
      <div class="ayira-footer__social">{%- render 'social-icons', class: 'ayira-footer__social-list' -%}</div>
    {%- endif -%}

    <div class="ayira-footer__bottom">
      {%- if section.settings.payment_enable -%}
        <div class="ayira-footer__payment">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="ayira-footer__copyright caption">
        <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}</small>
        {%- if section.settings.show_policy -%}
          <ul class="ayira-footer__policies list-unstyled">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}<li><a href="{{ policy.url }}">{{ policy.title | escape }}</a></li>{%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Ayira footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "blocks": [
    { "type": "@app" },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "default": "Explore", "label": "Heading" },
        { "type": "link_list", "id": "menu", "default": "footer", "label": "Menu" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "default": "About Ayira", "label": "Heading" },
        { "type": "richtext", "id": "subtext", "default": "<p>Thoughtfully selected essentials for everyday living.</p>", "label": "Text" }
      ]
    }
  ],
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-3" },
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "newsletter_enable", "default": true, "label": "Show newsletter" },
    { "type": "inline_richtext", "id": "newsletter_heading", "default": "Stay close to Ayira", "label": "Heading" },
    { "type": "richtext", "id": "newsletter_text", "default": "<p>New arrivals, useful ideas, and considered offers. No noise.</p>", "label": "Text" },
    { "type": "header", "content": "Footer options" },
    { "type": "checkbox", "id": "show_social", "default": true, "label": "Show social links" },
    { "type": "checkbox", "id": "payment_enable", "default": true, "label": "Show payment icons" },
    { "type": "checkbox", "id": "show_policy", "default": true, "label": "Show policy links" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "margin_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top margin", "default": 0 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 28 }
  ],
  "presets": [
    {
      "name": "Ayira footer",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
