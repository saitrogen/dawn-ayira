{
  "_readme": "Ayira × Dawn handoff format — produced alongside each design output. RGB values are Dawn-format integer triplets (no wrapper), for use as: rgba(var(--color-*), alpha). Every color reference inside sections and components is inlined as: token-name (hex / R,G,B) so you never need to cross-reference the colors block during implementation.",

  "meta": {
    "design": "Ayira Storefront — Home Page",
    "version": "v2",
    "date": "2026-05-28",
    "source_file": "Ayira Storefront Prototype.html",
    "css_file": "styles.css"
  },

  "breakpoints": {
    "mobile": "375px",
    "tablet": "768px",
    "desktop": "1280px",
    "content_max_width": "1280px",
    "container_gutter_desktop": "48px",
    "container_gutter_mobile": "16px",
    "sticky_header_activates": "any scroll > 0px — backdrop-filter blur(12px) + opacity 92%"
  },

  "colors": {
    "_note": "Complete palette. Copy rgb values into Dawn's settings_data.json or settings_schema.json color fields. Dawn wraps them as rgba(var(--color-*), alpha) internally.",
    "forest": {
      "900": { "hex": "#062E29", "rgb": "6,46,41",    "role": "deepest hover, overlay bg, modal scrim" },
      "800": { "hex": "#093E37", "rgb": "9,62,55",    "role": "primary button pressed state" },
      "700": { "hex": "#0D4F47", "rgb": "13,79,71",   "role": "PRIMARY — header bg, primary buttons, section headings" },
      "600": { "hex": "#1B6259", "rgb": "27,98,89",   "role": "eyebrow text, active nav indicator border" },
      "500": { "hex": "#2E7C72", "rgb": "46,124,114", "role": "success state (also = color-success)" },
      "100": { "hex": "#D7E4E1", "rgb": "215,228,225","role": "soft tint fills, focus rings, secondary button border" },
      "50":  { "hex": "#EBF1EF", "rgb": "235,241,239","role": "ghost button hover bg, input focus ring, variant active bg" }
    },
    "mustard": {
      "700": { "hex": "#A87F1B", "rgb": "168,127,27",  "role": "mustard hover" },
      "600": { "hex": "#BC9226", "rgb": "188,146,38",  "role": "mustard active / pressed" },
      "500": { "hex": "#D4A737", "rgb": "212,167,55",  "role": "ACCENT — sale badges, cart bubble, announcement CTA" },
      "300": { "hex": "#E8C97C", "rgb": "232,201,124", "role": "hero eyebrow text on forest bg" },
      "100": { "hex": "#F7EBC4", "rgb": "247,235,196", "role": "mustard soft fill" },
      "50":  { "hex": "#FBF5E2", "rgb": "251,245,226", "role": "mustard wash bg, active filter chip bg" }
    },
    "cream": {
      "50":  { "hex": "#FBFBF6", "rgb": "251,251,246", "role": "raised surfaces — cards, header bg (scrolled), footer-brand inputs" },
      "100": { "hex": "#F6F6EE", "rgb": "246,246,238", "role": "APP BACKGROUND — page canvas, cart drawer bg" },
      "200": { "hex": "#ECECDF", "rgb": "236,236,223", "role": "sunken sections, secondary button hover, icon button hover" },
      "300": { "hex": "#DCDCC8", "rgb": "220,220,200", "role": "deeper dividers, pressed secondary button" }
    },
    "ink": {
      "900": { "hex": "#101828", "rgb": "16,24,40",    "role": "headlines on cream (avoids green-on-green with forest-700)" },
      "700": { "hex": "#344054", "rgb": "52,64,84",    "role": "body text — fg-default" },
      "500": { "hex": "#667085", "rgb": "102,112,133", "role": "secondary / muted text — captions, meta, nav resting" },
      "400": { "hex": "#98A2B3", "rgb": "152,162,179", "role": "placeholder text, compare-at price strikethrough" },
      "300": { "hex": "#D0D5DD", "rgb": "208,213,221", "role": "disabled text, unavailable variant" },
      "200": { "hex": "#E4E7EC", "rgb": "228,231,236", "role": "card borders, input borders, divider lines" },
      "100": { "hex": "#F2F4F7", "rgb": "242,244,247", "role": "disabled chip bg, sold-out badge bg" }
    },
    "semantic": {
      "white":   { "hex": "#FFFFFF", "rgb": "255,255,255", "role": "card surface, modal bg, product image tile bg" },
      "success": { "hex": "#2E7C72", "rgb": "46,124,114",  "role": "in-stock indicator dot and label, confirmation states" },
      "warning": { "hex": "#D4A737", "rgb": "212,167,55",  "role": "warning state (same as mustard-500)" },
      "danger":  { "hex": "#B42318", "rgb": "180,35,24",   "role": "error text, limited badge, out-of-stock dot, remove button hover" },
      "info":    { "hex": "#175CD3", "rgb": "23,92,211",   "role": "informational state" }
    }
  },

  "typography": {
    "_note": "Single typeface system — Hanken Grotesk for everything. Weight, size, and color do the work of differentiation.",
    "typeface": "Hanken Grotesk",
    "source": "Google Fonts — family=Hanken+Grotesk:wght@300;400;500;600;700;800&display=swap",
    "weights": {
      "light": 300, "regular": 400, "medium": 500,
      "semibold": 600, "bold": 700, "extrabold": 800
    },
    "scale": {
      "display": { "size": "64px", "line_height": 1.05,  "letter_spacing": "-0.025em", "weight": 800 },
      "h1":      { "size": "48px", "line_height": 1.1,   "letter_spacing": "-0.022em", "weight": 700 },
      "h2":      { "size": "36px", "line_height": 1.15,  "letter_spacing": "-0.018em", "weight": 700 },
      "h3":      { "size": "28px", "line_height": 1.2,   "letter_spacing": "-0.014em", "weight": 600 },
      "h4":      { "size": "22px", "line_height": 1.3,   "letter_spacing": "-0.010em", "weight": 600 },
      "h5":      { "size": "18px", "line_height": 1.35,  "letter_spacing": "-0.005em", "weight": 600 },
      "body_lg": { "size": "18px", "line_height": 1.55 },
      "body":    { "size": "16px", "line_height": 1.55 },
      "body_sm": { "size": "14px", "line_height": 1.50 },
      "caption": { "size": "13px", "line_height": 1.45, "weight": 500 },
      "eyebrow": { "size": "11px", "line_height": 1.40, "letter_spacing": "0.08em", "weight": 600, "transform": "uppercase" },
      "price":   { "size": "20px", "weight": 700, "letter_spacing": "-0.01em" },
      "price_sm":{ "size": "15px", "weight": 600 }
    }
  },

  "spacing": {
    "_note": "4px base unit. Layouts breathe — section padding is generous on desktop.",
    "scale": {
      "1": "4px",  "2": "8px",  "3": "12px", "4": "16px",
      "5": "20px", "6": "24px", "8": "32px", "10": "40px",
      "12": "48px","16": "64px","20": "80px","24": "96px"
    },
    "section_padding_desktop": "64px 0",
    "section_padding_mobile":  "36px 0",
    "grid_gap_desktop": "24px",
    "grid_gap_mobile":  "12px"
  },

  "shape": {
    "radius_xs":  "4px",
    "radius_sm":  "8px",
    "radius_md":  "12px",
    "radius_lg":  "16px",
    "radius_xl":  "20px",
    "radius_2xl": "28px",
    "radius_pill":"999px"
  },

  "elevation": {
    "_note": "All shadows tinted with forest-700 (13,79,71) — never neutral gray. Results in cards that feel set on cream paper, not floating in space.",
    "xs": "0 1px 2px rgba(13,79,71,0.04)",
    "sm": "0 1px 3px rgba(13,79,71,0.06), 0 1px 2px rgba(13,79,71,0.04)",
    "md": "0 6px 16px -4px rgba(13,79,71,0.08), 0 2px 4px rgba(13,79,71,0.04)",
    "lg": "0 16px 32px -12px rgba(13,79,71,0.14), 0 4px 8px rgba(13,79,71,0.04)",
    "xl": "0 28px 56px -16px rgba(13,79,71,0.18), 0 8px 16px rgba(13,79,71,0.05)"
  },

