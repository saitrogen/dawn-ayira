  "pattern_intent": {
    "_note": "STRUCTURAL PATTERN = always present as a structural element, regardless of copy. CONDITIONAL = present only when a data condition is met. OPTIONAL SLOT = schema field — present when merchant fills it in, absent otherwise.",

    "hero_eyebrow_pip": {
      "type": "STRUCTURAL PATTERN",
      "description": "The filled 6px circle before hero eyebrow text is part of the design system — always present on hero eyebrows. It is not part of copywriting and should not vary by content.",
      "color": "mustard-500 (#D4A737 / 212,167,55)",
      "size": "6px",
      "dawn_implementation_note": "Render as a <span class='pip'></span> as the first child inside the eyebrow element — not a CSS ::before pseudo-element, which Dawn Liquid cannot easily target from schema settings. CSS: .pip { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); margin-right: 8px; vertical-align: middle; flex-shrink: 0; }. Place the span before any text node. If the eyebrow field is blank, the pip must not render — wrap both inside {% if section.settings.eyebrow != blank %}."
    },

    "eyebrow_dot_separator": {
      "type": "STRUCTURAL PATTERN",
      "description": "The · character between eyebrow segments (e.g. 'Store hours · Al Khor') is a design-pattern separator, not copy. Present whenever an eyebrow has two text segments. The segments either side are merchant-configurable.",
      "dawn_implementation_note": "Hard-code the · as a literal character between two schema text outputs: {{ section.settings.eyebrow_segment_1 }} · {{ section.settings.eyebrow_segment_2 }}. Do NOT use a CSS ::before or ::after — the separator must be a real text node so it wraps naturally with the copy on narrow viewports. Conditional render: {% if section.settings.eyebrow_segment_1 != blank and section.settings.eyebrow_segment_2 != blank %} — only show the separator if both parts are populated. If only one segment is present, render it alone with no separator."
    },

    "product_card_fav_icon": {
      "type": "STRUCTURAL PATTERN",
      "description": "The heart icon (top-right of product card image container) is always present on all product cards — a structural UI slot, not a decoration. Active state shows danger (#B42318 / 180,35,24) fill.",
      "dawn_implementation_note": "Dawn's card-product.liquid does not include a wishlist/fav button by default — this is a custom addition. Add a <button class='card__fav-btn' aria-label='Save {{ card_product.title }}'> element absolutely positioned inside .card__media (top: 10px; right: 10px). Use Lucide heart icon (stroke-width 1.75, 16px) inside a 32×32px button with border-radius: 999px; background: white; box-shadow: var(--shadow-xs). Toggle .is-active via JS; apply color: var(--color-danger) on .card__fav-btn.is-active. Persist wishlist state to localStorage keyed on product.id. If a third-party wishlist app is used, replace with its button — same position and size constraints apply."
    },

    "sale_badge": {
      "type": "CONDITIONAL STRUCTURAL PATTERN",
      "description": "SALE badge renders only when product.compare_at_price > product.price and the product is available. Never hard-coded or decorative.",
      "dawn_implementation_note": "Dawn renders this automatically in snippets/card-product.liquid when show_badges is true in theme settings. No custom code needed for the condition — Dawn handles: {% if card_product.compare_at_price > card_product.price %}. Configure the badge text via the sale_badge_text theme setting; the design uses 'SALE' or 'Save {percent}%'. The badge sits in a .card__badges container positioned absolute top-left 10px inside .card__media, stacking vertically when multiple badges coexist."
    },

    "section_eyebrow": {
      "type": "OPTIONAL SLOT",
      "description": "The small uppercase label above section headings is a schema text field — present only when the merchant fills it in. When empty, the heading moves up and the gap collapses cleanly. No fallback string.",
      "dawn_implementation_note": "Add to section schema: { 'type': 'text', 'id': 'eyebrow', 'label': 'Eyebrow label', 'info': 'Short uppercase label shown above the heading. Leave blank to hide.' }. Render conditionally: {% if section.settings.eyebrow != blank %}<p class='section-eyebrow'>{{ section.settings.eyebrow | escape }}</p>{% endif %}. Never insert a default or placeholder value — an empty setting should produce exactly zero rendered HTML."
    },

    "announcement_bar_cta": {
      "type": "OPTIONAL SLOT",
      "description": "The underlined CTA link at the end of announcement bar messages is a separate schema field from the message text. Optional — renders nothing if left blank.",
      "dawn_implementation_note": "Dawn's announcement bar block already includes button_label and button_link block settings. The CTA renders as <a class='announcement-bar__link'> when button_label is non-blank. Style the underline in your CSS override: .announcement-bar__link { color: var(--color-mustard-500); text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1.5px; font-weight: 700; }. The color must be set explicitly because Dawn's default announcement bar uses an inverse scheme where link color inherits from the text color token."
    },

    "collection_card_count": {
      "type": "STRUCTURAL PATTERN",
      "description": "The small product count label below a collection title is always present. Populated from collection.products_count — never hard-coded.",
      "dawn_implementation_note": "Output as: <p class='collection-card__count'>{{ collection.products_count }} {{ 'general.accessibility.product_count' | t: count: collection.products_count }}</p>. Use Dawn's translation key for correct pluralization (1 item / 24 items). Style: font-size 12px; color: cream-50 at 80% opacity when rendered over a dark overlay (opacity: 0.8 on the element). The count is always present — if a collection has zero products it shows '0 items', not a hidden element."
    },

    "footer_nav_columns": {
      "type": "STRUCTURAL PATTERN",
      "description": "Footer renders 4 link-list menu columns (columns 2–5 of the 5-column desktop grid). Column 1 is always the brand/newsletter block. Each column is a separate Shopify menu.",
      "dawn_implementation_note": "Each link-list column is a Dawn footer section block of type 'link_list'. Add 4 blocks in the customizer, each pointing to a separate navigation menu handle (e.g. footer-shop, footer-help, footer-company, footer-legal). In the liquid: {% for block in section.blocks %}{% if block.type == 'link_list' %}<div class='footer-col'>{% for link in linklists[block.settings.menu].links %}<a href='{{ link.url }}'>{{ link.title }}</a>{% endfor %}</div>{% endif %}{% endfor %}. The brand column (newsletter + social + logo) is a separate block type rendered first, occupying the 2fr column slot."
    }
  },

  "css_annotation_key": {
    "_note": "Every CSS block in styles.css output is marked at its opening comment with one of these three labels. Use this to decide what to carry into Dawn.",
    "KEEP — Design token": "Map to Dawn theme settings, section schema, or a CSS custom property override in your theme.css. These are real design decisions.",
    "KEEP — Component style": "Mirrors the visual design of a Dawn section or snippet. Adapt class names to Dawn's BEM conventions before using.",
    "DISCARD — Prototype scaffold": "Layout and chrome written to make the browser/phone prototype display correctly. Not needed in a real Shopify theme."
  }
}
